      { "type": "order", "prompt": "Соберите предложение", "words": ["No", "tengo", "nada"], "answer": ["No", "tengo", "nada"] },
      { "type": "fill", "prompt": "No hay ___ en casa. (никого)", "answer": "nadie", "hint": "никто/никого" }
    ]
  },
  {
    "title": "MUY или MUCHO",
    "level": "A1",
    "order": 27,
    "theory": [
      { "type": "paragraph", "text": "MUY (очень) ставится перед прилагательными и наречиями и не изменяется. MUCHO (много/очень) идёт с существительными (согласуется) или после глагола." },
      { "type": "table", "headers": ["MUY + ...", "MUCHO + ..."], "rows": [["muy alto", "mucho dinero"], ["muy bien", "muchas personas"], ["muy rápido", "Trabajo mucho"]] },
      { "type": "example", "es": "Es muy alto y trabaja mucho.", "ru": "Он очень высокий и много работает." }
    ],
    "exercises": [
      { "type": "mcq", "prompt": "Ella es ___ inteligente.", "options": ["muy", "mucho", "mucha", "muchos"], "answer": 0 },
      { "type": "fill", "prompt": "Tengo ___ trabajo. (много, м.р. ед.ч.)", "answer": "mucho", "hint": "+ существительное" },
      { "type": "mcq", "prompt": "Hay ___ personas.", "options": ["muy", "mucho", "muchas", "mucha"], "answer": 2 },
      { "type": "fill", "prompt": "Hablas ___ bien español. (очень)", "answer": "muy", "hint": "+ наречие" },
      { "type": "mcq", "prompt": "Estudio ___. (много, после глагола)", "options": ["muy", "mucho", "muchos", "mucha"], "answer": 1 },
