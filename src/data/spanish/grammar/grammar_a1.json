      { "type": "mcq", "prompt": "___ está el baño? (Где?)", "options": ["Qué", "Quién", "Dónde", "Cuándo"], "answer": 2 },
      { "type": "fill", "prompt": "¿___ es esto? (Что это?)", "answer": "Qué", "hint": "что" },
      { "type": "mcq", "prompt": "___ es él? (Кто он?)", "options": ["Qué", "Quién", "Cómo", "Cuánto"], "answer": 1 },
      { "type": "fill", "prompt": "¿___ cuesta? (Сколько стоит?)", "answer": "Cuánto", "hint": "сколько" },
      { "type": "order", "prompt": "Соберите вопрос", "words": ["¿Dónde", "vives", "tú?"], "answer": ["¿Dónde", "vives", "tú?"] },
      { "type": "mcq", "prompt": "___ no vienes? (Почему?)", "options": ["Cómo", "Cuándo", "Por qué", "Qué"], "answer": 2 }
