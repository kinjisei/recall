      { "type": "fill", "prompt": "No ___ comas. (lo — позиция)", "answer": "lo", "hint": "no + lo + глагол" },
      { "type": "order", "prompt": "Соберите команду", "words": ["No", "te", "preocupes"], "answer": ["No", "te", "preocupes"] },
      { "type": "mcq", "prompt": "Отрицательная форма «hazlo»:", "options": ["no hazlo", "no lo hagas", "no haces lo", "no lo haces"], "answer": 1 }
