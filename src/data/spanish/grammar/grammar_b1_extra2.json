      { "type": "order", "prompt": "Соберите предложение", "words": ["Tengo", "sueño,", "por", "eso", "me", "acuesto"], "answer": ["Tengo", "sueño,", "por", "eso", "me", "acuesto"] },
      { "type": "mcq", "prompt": "Es tarde y, ___, estoy cansado. (добавление)", "options": ["además", "pero", "porque", "aunque"], "answer": 0 }
    ]
  },
  {
