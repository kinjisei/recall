      { "type": "mcq", "prompt": "«Estoy en casa» → Me dijo que ___ en casa.", "options": ["está", "estaba", "estaría", "estuvo"], "answer": 1 },
      { "type": "mcq", "prompt": "«He terminado» → Dijo que ___ terminado.", "options": ["ha", "había", "habría", "haya"], "answer": 1 },
      { "type": "fill", "prompt": "«Te ayudaré» → Dijo que me ___. (ayudar → ayudaría)", "answer": "ayudaría", "hint": "condicional" },
      { "type": "order", "prompt": "Соберите предложение", "words": ["Dijo", "que", "estaba", "ocupado"], "answer": ["Dijo", "que", "estaba", "ocupado"] },
      { "type": "mcq", "prompt": "«Quiero verte» → Dijo que ___ verme.", "options": ["quiere", "quería", "querría", "quiso"], "answer": 1 }
    ]
  },
  {
    "title": "Глаголы изменения (ponerse, volverse, hacerse)",
    "level": "B1",
    "order": 29,
    "theory": [
      { "type": "paragraph", "text": "В испанском «становиться» передаётся разными глаголами в зависимости от характера изменения: ponerse (временное состояние), volverse (внезапное/непроизвольное), hacerse (постепенное, по усилию), llegar a ser (достижение цели)." },
      { "type": "table", "headers": ["Глагол", "Тип изменения", "Пример"], "rows": [["ponerse", "временное состояние", "Se puso nervioso"], ["volverse", "резкое, характер", "Se volvió loco"], ["hacerse", "постепенное", "Se hizo rico"], ["llegar a ser", "достижение", "Llegó a ser director"]] },
      { "type": "example", "es": "Cuando la vio, se puso muy contento.", "ru": "Когда он её увидел, он очень обрадовался." }
    ],
    "exercises": [
      { "type": "mcq", "prompt": "Se ___ rojo de vergüenza. (временное → ponerse)", "options": ["puso", "volvió", "hizo", "llegó"], "answer": 0 },
      { "type": "mcq", "prompt": "Con los años se ___ médico. (постепенно)", "options": ["puso", "volvió", "hizo", "quedó"], "answer": 2 },
      { "type": "fill", "prompt": "Me ___ nervioso antes del examen. (ponerse, yo → pongo)", "answer": "pongo", "hint": "ponerse, yo" },
      { "type": "mcq", "prompt": "Después del accidente se ___ muy callado. (резкая перемена)", "options": ["puso", "volvió", "hizo", "llegó a ser"], "answer": 1 },
      { "type": "mcq", "prompt": "Estudió mucho y ___ a ser ingeniero.", "options": ["se puso", "se volvió", "se hizo", "llegó"], "answer": 3 },
      { "type": "order", "prompt": "Соберите предложение", "words": ["Se", "puso", "muy", "contenta"], "answer": ["Se", "puso", "muy", "contenta"] },
      { "type": "mcq", "prompt": "«Он разбогател (постепенно)»:", "options": ["Se puso rico", "Se hizo rico", "Se volvió rico", "Llegó rico"], "answer": 1 }
    ]
  },
  {
    "title": "Коннекторы речи (причина, следствие, контраст)",
    "level": "B1",
    "order": 30,
    "theory": [
      { "type": "paragraph", "text": "Коннекторы связывают идеи: причина (porque, ya que), следствие (por eso, así que, por lo tanto), контраст (pero, sin embargo, aunque), добавление (además)." },
      { "type": "table", "headers": ["Тип", "Коннекторы"], "rows": [["причина", "porque, ya que, como"], ["следствие", "por eso, así que, por lo tanto"], ["контраст", "pero, sin embargo, aunque"], ["добавление", "además, también"]] },
      { "type": "example", "es": "Estaba cansado, así que me fui a casa.", "ru": "Я устал, поэтому пошёл домой." }
    ],
    "exercises": [
      { "type": "mcq", "prompt": "No vino ___ estaba enfermo. (причина)", "options": ["porque", "por eso", "sin embargo", "además"], "answer": 0 },
      { "type": "mcq", "prompt": "Llovía; ___ no salimos. (следствие)", "options": ["porque", "por eso", "aunque", "ya que"], "answer": 1 },
      { "type": "fill", "prompt": "Es caro; ___ embargo, lo compraré. (контраст)", "answer": "sin", "hint": "sin embargo" },
      { "type": "mcq", "prompt": "___ llueve, saldremos. (даже если)", "options": ["Porque", "Aunque", "Por eso", "Ya que"], "answer": 1 },
