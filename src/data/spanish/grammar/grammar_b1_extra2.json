[
  {
    "title": "Subjuntivo с союзами (cuando, para que, antes de que)",
    "level": "B1",
    "order": 26,
    "theory": [
      { "type": "paragraph", "text": "После некоторых союзов, когда речь о будущем или цели, используется subjuntivo: cuando (когда, о будущем), para que (чтобы), antes de que (прежде чем), aunque (даже если)." },
      { "type": "table", "headers": ["Союз", "Пример"], "rows": [["cuando + subj.", "Cuando llegues, llámame"], ["para que + subj.", "Te lo digo para que lo sepas"], ["antes de que + subj.", "Sal antes de que llueva"]] },
      { "type": "example", "es": "Cuando tenga tiempo, te visitaré.", "ru": "Когда у меня будет время, я тебя навещу." }
    ],
    "exercises": [
      { "type": "mcq", "prompt": "Cuando ___ a casa, descansaré. (llegar)", "options": ["llego", "llegue", "llegaré", "llegaba"], "answer": 1 },
      { "type": "fill", "prompt": "Te lo explico para que lo ___. (entender, tú → entiendas)", "answer": "entiendas", "hint": "para que + subj." },
      { "type": "mcq", "prompt": "Sal antes de que ___ tarde. (ser)", "options": ["es", "sea", "será", "era"], "answer": 1 },
      { "type": "fill", "prompt": "Cuando ___ grande, seré médico. (ser → sea)", "answer": "sea", "hint": "будущее → subj." },
      { "type": "mcq", "prompt": "Trabajo para que mi familia ___ bien. (vivir)", "options": ["vive", "viva", "vivirá", "vivía"], "answer": 1 },
      { "type": "order", "prompt": "Соберите предложение", "words": ["Llámame", "cuando", "puedas"], "answer": ["Llámame", "cuando", "puedas"] },
      { "type": "mcq", "prompt": "Llegaremos antes de que ___ el concierto. (empezar)", "options": ["empieza", "empiece", "empezará", "empezaba"], "answer": 1 }
    ]
  },
  {
