  {
    "title": "Косвенная речь (estilo indirecto)",
    "level": "B1",
    "order": 28,
    "theory": [
      { "type": "paragraph", "text": "При передаче чужих слов времена и местоимения смещаются. Presente → imperfecto, futuro → condicional, pretérito perfecto → pluscuamperfecto." },
      { "type": "table", "headers": ["Прямая речь", "Косвенная речь"], "rows": [["«Estoy cansado»", "Dijo que estaba cansado"], ["«Vendré»", "Dijo que vendría"], ["«He comido»", "Dijo que había comido"]] },
      { "type": "example", "es": "Dijo que me llamaría más tarde.", "ru": "Он сказал, что позвонит мне позже." }
    ],
    "exercises": [
      { "type": "mcq", "prompt": "«Tengo hambre» → Dijo que ___ hambre.", "options": ["tiene", "tenía", "tendría", "tuvo"], "answer": 1 },
