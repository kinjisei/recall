      { "type": "fill", "prompt": "Наречие от «lento»: ___.", "answer": "lentamente", "hint": "lenta + mente" },
      { "type": "mcq", "prompt": "___ desayuno en casa. (обычно)", "options": ["Normalmente", "Normal", "Normalemente", "Normamente"], "answer": 0 },
      { "type": "fill", "prompt": "Наречие от «tranquilo»: ___.", "answer": "tranquilamente", "hint": "tranquila + mente" },
      { "type": "order", "prompt": "Соберите предложение", "words": ["Conduce", "muy", "lentamente"], "answer": ["Conduce", "muy", "lentamente"] },
      { "type": "mcq", "prompt": "Наречие от «perfecto»:", "options": ["perfectomente", "perfectamente", "perfectemente", "perfectimente"], "answer": 1 }
